@article{rouaultPsychiatricSymptomDimensions2018,
  title = {Psychiatric {{Symptom Dimensions Are Associated With Dissociable Shifts}} in {{Metacognition}} but {{Not Task Performance}}},
  author = {Rouault, Marion and Seow, Tricia and Gillan, Claire M. and Fleming, Stephen M.},
  date = {2018},
  journaltitle = {Biological Psychiatry},
  shortjournal = {Biological Psychiatry},
  series = {Translating {{Biology}} to {{Treatment}} in {{Schizophrenia}}},
  volume = {84},
