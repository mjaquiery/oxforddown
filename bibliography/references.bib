@article{collinsBidirectionalRelationshipSource2018,
  title = {The {{Bi}}-Directional {{Relationship}} between {{Source Characteristics}} and {{Message Content}}},
  author = {Collins, Peter J. and Hahn, Ulrike and von Gerber, Ylva and Olsson, Erik J.},
  options = {useprefix=true},
  date = {2018},
  journaltitle = {Frontiers in Psychology},
  shortjournal = {Front. Psychol.},
